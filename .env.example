# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Aurora PostgreSQL ───────────────────────────────────────────────────────
# Writer endpoint — use for all mutations and live match reads
DB_WRITER_URL="postgresql://fotnob:password@writer.cluster-xxxx.us-east-1.rds.amazonaws.com:5432/fotnob?connection_limit=10&pool_timeout=20"

# Reader endpoint — use for slower-changing data (standings, profiles, news)
DB_READER_URL="postgresql://fotnob:password@reader.cluster-xxxx.us-east-1.rds.amazonaws.com:5432/fotnob?connection_limit=10&pool_timeout=20"

# Local dev — use the same URL for both
# DB_WRITER_URL="postgresql://fotnob:fotnob@localhost:5432/fotnob"
# DB_READER_URL="postgresql://fotnob:fotnob@localhost:5432/fotnob"

# Required by Prisma CLI (prisma studio, prisma migrate) — must match DB_WRITER_URL
# Local dev:
DATABASE_URL="postgresql://fotnob:fotnob@localhost:5432/fotnob"
# Production: set this to the same value as DB_WRITER_URL above

# ─── Redis / ElastiCache ─────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_TTL_DEFAULT=300

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET="change_me_access_secret_min_32_chars_xxxxx"
JWT_REFRESH_SECRET="change_me_refresh_secret_min_32_chars_xxxxxx"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── API-Football (RapidAPI) ──────────────────────────────────────────────────
RAPIDAPI_KEY="your_rapidapi_key_here"
RAPIDAPI_HOST="api-football-v1.p.rapidapi.com"

# ─── Throttle ────────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:4200,http://localhost:3000"
